# Code signing
APPLE_SIGNING_IDENTITY=Developer ID Application: Your Name (TEAMID)

# Optional backup for CI or recovery only.
# APPLE_CERTIFICATE=op://Mac%20Development/Red%20Pen%20Signing/apple_certificate_base64
# APPLE_CERTIFICATE_PASSWORD=op://Mac%20Development/Red%20Pen%20Signing/apple_certificate_password

# Choose one notarization method.

# Apple ID + app-specific password
APPLE_ID=op://Mac%20Development/Red%20Pen%20Notarization/apple_id
APPLE_PASSWORD=op://Mac%20Development/Red%20Pen%20Notarization/app_specific_password
APPLE_TEAM_ID=op://Mac%20Development/Red%20Pen%20Notarization/team_id

# App Store Connect API key
# APPLE_API_KEY=op://Mac%20Development/Red%20Pen%20Notarization/api_key_id
# APPLE_API_ISSUER=op://Mac%20Development/Red%20Pen%20Notarization/api_issuer_id
# APPLE_API_KEY_CONTENT=op://Mac%20Development/Red%20Pen%20Notarization/AuthKey_ABC123XYZ.p8
