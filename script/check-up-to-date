#!/usr/bin/env bash
# Check that the current branch is up to date with its remote tracking branch.
set -euo pipefail

branch=$(git rev-parse --abbrev-ref HEAD)
remote=$(git config --get "branch.${branch}.remote" 2>/dev/null || echo "")

if [[ -z "$remote" ]]; then
  echo "No remote tracking branch for '$branch', skipping up-to-date check"
  exit 0
fi

git fetch "$remote" "$branch" --quiet

remote_ref="$remote/$branch"
behind=$(git rev-list --count "HEAD..${remote_ref}" 2>/dev/null || echo "0")

if [[ "$behind" -gt 0 ]]; then
  echo "ERROR: '$branch' is $behind commit(s) behind '$remote_ref'. Pull before pushing."
  exit 1
fi

echo "OK: '$branch' is up to date with '$remote_ref'"
